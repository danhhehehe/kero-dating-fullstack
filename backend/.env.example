NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
RESET_PASSWORD_URL=http://localhost:5173/reset-password
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
COOKIE_SECURE=false
DEBUG_RESET_LINK=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_APP_PASSWORD=your-google-app-password
MAIL_FROM=Kero Security <your-email@gmail.com>
MONGODB_URI=mongodb://127.0.0.1:27017/kero_dating
JWT_SECRET=change_me_to_at_least_32_characters
JWT_EXPIRES_IN=7d
ADMIN_EMAIL=admin@kero.local
ADMIN_PASSWORD=admin12345
DEMO_USERS_ENABLED=true
DEMO_USERS_PREFIX=q
DEMO_USERS_DOMAIN=kero.local
DEMO_DEFAULT_PASSWORD=demo12345

